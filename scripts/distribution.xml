<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>TrustGate</title>
    <options customize="never" require-scripts="false" hostArchitectures="x86_64,arm64"/>
    <os-version min="10.15"/>

    <welcome file="welcome.html" mime-type="text/html"/>

    <choices-outline>
        <line choice="default">
            <line choice="com.trustgate.agent.pkg"/>
        </line>
    </choices-outline>

    <choice id="default"/>
    <choice id="com.trustgate.agent.pkg" visible="false">
        <pkg-ref id="com.trustgate.agent.pkg"/>
    </choice>

    <pkg-ref id="com.trustgate.agent.pkg" version="__VERSION__" onConclusion="none">trustgate-component.pkg</pkg-ref>
</installer-gui-script>
