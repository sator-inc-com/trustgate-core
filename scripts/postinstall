#!/bin/bash
# TrustGate macOS .pkg post-install script
# Sets up directories, fixes plist paths, and starts the agent service

set -e

CONFIG_DIR="/Library/Application Support/TrustGate"
LOG_DIR="$HOME/Library/Logs/TrustGate"
CONFIG_PATH="${CONFIG_DIR}/agent.yaml"
AGENT_PLIST="/Library/LaunchAgents/com.trustgate.agent.plist"
TRAY_PLIST="/Library/LaunchAgents/com.trustgate.tray.plist"

# Create directories
mkdir -p "$CONFIG_DIR"
mkdir -p "$LOG_DIR"
chmod 755 "$LOG_DIR"

# Fix plist placeholders
if [ -f "$AGENT_PLIST" ]; then
    sed -i '' "s|__CONFIG_PATH__|${CONFIG_PATH}|g" "$AGENT_PLIST"
    sed -i '' "s|__CONFIG_DIR__|${CONFIG_DIR}|g" "$AGENT_PLIST"
    sed -i '' "s|__LOG_DIR__|${LOG_DIR}|g" "$AGENT_PLIST"
fi

# Note: LaunchAgents are loaded per-user at login.
# We don't load them here because postinstall runs as root.
# Instead, open the tray app which will handle agent startup.
if [ -d "/Applications/TrustGate.app" ]; then
    CONSOLE_USER=$(stat -f "%Su" /dev/console)
    if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
        # Load agent plist for the console user
        sudo -u "$CONSOLE_USER" launchctl load "$AGENT_PLIST" 2>/dev/null || true
        # Load tray plist and open app
        if [ -f "$TRAY_PLIST" ]; then
            sudo -u "$CONSOLE_USER" launchctl load "$TRAY_PLIST" 2>/dev/null || true
        fi
        sudo -u "$CONSOLE_USER" open /Applications/TrustGate.app 2>/dev/null || true
    fi
fi

echo "TrustGate installed. The agent will start automatically at login."

exit 0
